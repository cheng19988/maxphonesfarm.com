# Copy to .env for local development

# PostgreSQL (required). Use Neon in production.
# Neon: use the *pooled* connection string from the Neon dashboard (host contains -pooler).
# Append sslmode=require if not already present:
# postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

JWT_SECRET="change-this-to-a-random-secret-in-production"
ADMIN_EMAIL="admin@maxphonesfarm.com"
ADMIN_PASSWORD="your-secure-password-min-12-chars"
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_NOTIFY_CHAT_ID=""
# TRON_API_KEY=""  # Optional: TronGrid API key for USDT payment verification
